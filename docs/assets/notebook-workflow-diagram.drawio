<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Notebook Workflow">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="PassiveLAB Golden T-Coil Notebook — Workflow" style="text;html=1;fontSize=22;fontStyle=1;align=left;verticalAlign=middle;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="0" width="700" height="30" as="geometry" />
        </mxCell>

        <!-- Row 1: stages 0-3, left to right -->
        <mxCell id="s0" value="&lt;b&gt;Stage 0&lt;/b&gt;&lt;br&gt;Environment Setup&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Tools: IHP SG13G2 PDK, ngspice,&lt;br&gt;openEMS, CUDA&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Output: GDS/, SPData/, EMLOG/ dirs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;align=center;verticalAlign=middle;spacing=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="260" height="140" as="geometry" />
        </mxCell>

        <mxCell id="s1" value="&lt;b&gt;Stage 1&lt;/b&gt;&lt;br&gt;T-Coil Peaking Theory&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Tools: (derivation only)&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;Output: peaking equations (L, C_B, k)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#333333;align=center;verticalAlign=middle;spacing=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="50" width="260" height="140" as="geometry" />
        </mxCell>

        <mxCell id="s2" value="&lt;b&gt;Stage 2&lt;/b&gt;&lt;br&gt;Parametric Geometry&lt;br&gt;Generator&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[ext-tool] gdspy&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[artifact] tcoil_bias_test.gds&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#333333;align=center;verticalAlign=middle;spacing=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="640" y="50" width="260" height="140" as="geometry" />
        </mxCell>

        <mxCell id="s3" value="&lt;b&gt;Stage 3&lt;/b&gt;&lt;br&gt;EM Simulation&lt;br&gt;(batched / distributed)&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[ext-tool] openEMS, CSXCAD, Ray&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[artifact] .s3p Touchstone files&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#333333;align=center;verticalAlign=middle;spacing=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="940" y="50" width="260" height="140" as="geometry" />
        </mxCell>

        <!-- Row 2: stages 4-7, right to left (boustrophedon) -->
        <mxCell id="s4" value="&lt;b&gt;Stage 4&lt;/b&gt;&lt;br&gt;ANN Surrogate Model&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[ext-tool] PyTorch, scikit-rf&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[artifact] deeper_mlp_model.pt +&lt;br&gt;normalization arrays&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;align=center;verticalAlign=middle;spacing=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="940" y="290" width="260" height="140" as="geometry" />
        </mxCell>

        <mxCell id="s5" value="&lt;b&gt;Stage 5&lt;/b&gt;&lt;br&gt;SPICE Netlist&lt;br&gt;Generation&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[ext-tool] ngspice&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[artifact] .cir netlists&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#333333;align=center;verticalAlign=middle;spacing=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="640" y="290" width="260" height="140" as="geometry" />
        </mxCell>

        <mxCell id="s6" value="&lt;b&gt;Stage 6&lt;/b&gt;&lt;br&gt;CMA-ES Inverse Design&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[ext-tool] Optuna (CmaEsSampler),&lt;br&gt;spicelib, multiprocessing&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;[artifact] optimized geometry +&lt;br&gt;verification plots&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#333333;align=center;verticalAlign=middle;spacing=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="290" width="260" height="140" as="geometry" />
